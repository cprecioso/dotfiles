{{- $personal := promptBoolOnce . "personal" "Add Personal files" -}}
{{- $wasp   := promptBoolOnce . "wasp"   "Add Wasp files"   -}}

[data]
  personal = {{ $personal | toToml }}
  wasp   = {{ $wasp   | toToml }}

[merge]
command = "bash"
args = [
  "-c",
  {{ printf "%q" "cp {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} && code --new-window --wait --merge {{ .Destination | quote }} {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} {{ .Source | quote }}" }},
]
