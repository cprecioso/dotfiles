[tools]
node = "lts"
deno = "latest"
prettier = "latest"
uv = "latest"
corepack = "latest"
claude = "latest"
codex = "latest"
opencode = "latest"

{{- if .personal }}
tuist = "latest"
{{- end }}

[tool_alias]
wasp = "npm:@wasp.sh/wasp-cli"
corepack = "npm:corepack"
prettier = "npm:prettier"

[env]
TRY_DIR = "{{.chezmoi.config.destDir}}/Developer/Personal/try"

[settings]
lockfile = true
experimental = true

[settings.pipx]
uvx = true
