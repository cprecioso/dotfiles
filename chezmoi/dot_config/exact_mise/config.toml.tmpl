[tools]
node = "lts"
deno = "latest"
"npm:corepack" = "latest"
uv = "latest"
prettier = "latest"
codex = "latest"
opencode = "latest"

{{- if .personal }}
tuist = "latest"
{{- end }}

[shell_alias]
ghostty = "open -a Ghostty"

[env]
TRY_DIR = "{{.chezmoi.config.destDir}}/Developer/Personal/try"
TRY_ACTIONS_FILE = "{{.chezmoi.config.destDir}}/.config/try/actions.bash"

[settings]
lockfile = true
minimum_release_age = "7d"

[settings.node]
corepack = true
npm_shim = false

[settings.github]
use_git_credentials = true
