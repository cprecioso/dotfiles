{{/* Definitions */}}

{{ $data := . }}
{{
  $profiles :=
    dict
      "common" true
      "personal" .personal
      "wasp" .wasp
}}

{{/* Kinds */}}

{{ define "mas" }}
{{ range $name, $id := .mas }}
mas {{ $name | quote }}, id: {{ $id }}
{{ end }}
{{ end }}

{{ define "tap" }}
{{ range .tap }}
tap {{ . | quote }}
{{ end }}
{{ end }}

{{ define "cask" }}
{{ range .cask }}
cask {{ . | quote }}
{{ end }}
{{ end }}

{{ define "formula" }}
{{ $profile_data := . }}
{{ range .formula }}
brew {{ . | quote }}
{{- if (has . (get $profile_data "service")) -}} , restart_service: true {{- end }}
{{ end }}
{{ end }}

{{/* Brew bundle */}}

{{ range $name, $enabled := $profiles }}
{{ if $enabled }}
{{ template "mas" (get $data.brew_packages $name) }}
{{ end }}
{{ end }}

{{ range $name, $enabled := $profiles }}
{{ if $enabled }}
{{ template "tap" (get $data.brew_packages $name) }}
{{ end }}
{{ end }}

{{ range $name, $enabled := $profiles }}
{{ if $enabled }}
{{ template "cask" (get $data.brew_packages $name) }}
{{ end }}
{{ end }}

{{ range $name, $enabled := $profiles }}
{{ if $enabled }}
{{ template "formula" (get $data.brew_packages $name) }}
{{ end }}
{{ end }}
